pipeline {
	agent any
	environment {
		nome = 'echo-demo'
		immagine = 'ealen/echo-server'
	}

	stages {
		stage ("pull immagine"){
			steps {
				sh "docker pull ${immagine}"
			}
		}
		stage ("pull e run immagine"){
			steps {
				sh "docker pull ${immagine}"
				sh "docker run -d -p 5000:80 --name ${nome} ${immagine}"
			}
		}
		stage ("stato container"){
			steps {
				sh "docker inspect ${nome}"
			}

		}
	}
	post {
		always {
			sh "docker stop ${nome}"
			sh "docker rm -f ${nome}"
		}

	}
}